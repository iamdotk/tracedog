{
  "name": "@iamdotk/tracedog-cli",
  "version": "0.1.0",
  "description": "Track Datadog traces from your terminal.",
  "type": "module",
  "bin": {
    "tracedog": "./dist/bin/tracedog.js"
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamdotk/tracedog.git"
  },
  "homepage": "https://github.com/iamdotk/tracedog#readme",
  "bugs": "https://github.com/iamdotk/tracedog/issues",
  "license": "MIT",
  "keywords": ["datadog", "apm", "cli", "claude", "openai", "agent", "observability", "traces"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx ./bin/tracedog.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@iamdotk/tracedog-core": "workspace:*",
    "@inquirer/prompts": "^7.2.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
